// numbers, strings, and booleans all living together peacefully!
// a real program uses ALL the types!

name = "Guppy"
version = 1
isFun = true
score = 98.5

out(name)
out(version)
out(isFun)
out(score)

if isFun and score > 90
    out(name + " is awesome!")

for i in range(1 through 2)
    out(i)
